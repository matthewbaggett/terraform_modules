terraform {
  required_version = "~> 1.6"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.0"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.5"
    }
    null = {
      source  = "hashicorp/null"
      version = "~> 3.0"
    }
    ssh = {
      source = "AndrewChubatiuk/ssh"
    }
    scratch = {
      source  = "BrendanThompson/scratch"
      version = "~> 0.4"
    }
  }
}
